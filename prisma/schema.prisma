// ============================================================
// PLOS database schema — Phase M
// User-facing concept: "Project" (one product launch effort)
// Internal structure: Project + ProjectWorkflow (user never sees
// the name "ProjectWorkflow" — it's pure DB implementation)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Project — user-facing record.
// One Project = one product launch effort.
// Flows through all 14 PLOS workflows via ProjectWorkflow rows.
// ============================================================
model Project {
  id          String   @id @default(uuid())
  userId      String
  name        String   @default("Untitled Project")
  description String   @default("") @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflows         ProjectWorkflow[]
  vocabularyEntries VocabularyEntry[]

  @@index([userId])
}

// ============================================================
// ProjectWorkflow — internal per-workflow state + data bucket.
// User never sees this name in the UI.
// Auto-created on first workflow entry; auto-transitions
// "inactive" -> "active" on first real action; "completed"
// is user-marked.
// ============================================================
model ProjectWorkflow {
  id              String    @id @default(uuid())
  projectId       String
  workflow        String // "keyword-clustering", etc.
  status          String    @default("inactive") // "inactive" | "active" | "completed"
  firstActivityAt DateTime?
  lastActivityAt  DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keywords        Keyword[]
  removedKeywords RemovedKeyword[]
  canvasNodes     CanvasNode[]
  pathways        Pathway[]
  sisterLinks     SisterLink[]
  canvasState     CanvasState?
  competitorUrls  CompetitorUrl[]

  @@unique([projectId, workflow])
  @@index([projectId])
}

// ============================================================
// Keyword — attached to a workflow instance (was: Project).
// All fields unchanged; only the foreign key target changed.
// ============================================================
model Keyword {
  id                String   @id @default(uuid())
  projectWorkflowId String
  keyword           String
  volume            Int      @default(0)
  sortingStatus     String   @default("Unsorted")
  tags              String   @default("")
  topic             String   @default("")
  canvasLoc         Json     @default("{}")
  topicApproved     Json     @default("{}")
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

// ============================================================
// CanvasNode — attached to a workflow instance (was: Project).
// All fields unchanged; only the foreign key target changed.
// ============================================================
model CanvasNode {
  id                String   @id @default(uuid())
  projectWorkflowId String
  title             String   @default("")
  description       String   @default("")
  x                 Float    @default(0)
  y                 Float    @default(0)
  w                 Float    @default(220)
  h                 Float    @default(120)
  baseY             Float    @default(0)
  pathwayId         String?
  parentId          String?
  relationshipType  String   @default("")
  linkedKwIds       Json     @default("[]")
  kwPlacements      Json     @default("{}")
  collapsedLinear   Boolean  @default(false)
  collapsedNested   Boolean  @default(false)
  narrativeBridge   String   @default("")
  altTitles         Json     @default("[]")
  userMinH          Float?
  connCP            Json?
  connOutOff        Json?
  connInOff         Json?
  sortOrder         Int      @default(0)
  stableId          String
  stabilityScore    Float    @default(0.0)
  // Intent fingerprint — short canonical phrase (5–15 words, searcher-centric)
  // capturing a topic's compound intent. Load-bearing for Tiered Canvas
  // Serialization (Scale Sessions B–E in INPUT_CONTEXT_SCALING_DESIGN.md).
  // Scale Session B Step 1: nullable. Step 2: AI backfill. Step 3: NOT NULL.
  intentFingerprint String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@unique([projectWorkflowId, stableId])
  @@index([projectWorkflowId])
}

// ============================================================
// RemovedKeyword — soft-archive of keywords removed from an
// AST table. Preserves the keyword's prior state so admin can
// review or restore. Two removal sources today:
//   "manual" — admin clicked Remove in the AST table
//   "auto-ai-detected-irrelevant" — Auto-Analyze salvage
//   mechanism flagged as irrelevant (Session 3b)
// `aiReasoning` is the model's text rationale for auto removals.
// ============================================================
model RemovedKeyword {
  id                String   @id @default(uuid())
  projectWorkflowId String
  originalKeywordId String?
  keyword           String
  volume            Int      @default(0)
  sortingStatus     String   @default("Unsorted")
  tags              String   @default("")
  topic             String   @default("")
  canvasLoc         Json     @default("{}")
  removedAt         DateTime @default(now())
  removedBy         String
  removedSource     String   @default("manual")
  aiReasoning       String?  @db.Text

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

model Pathway {
  id                String   @id @default(uuid())
  projectWorkflowId String
  createdAt         DateTime @default(now())

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

model SisterLink {
  id                String   @id @default(uuid())
  projectWorkflowId String
  nodeA             String
  nodeB             String
  createdAt         DateTime @default(now())

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

model CanvasState {
  id                String @id @default(uuid())
  projectWorkflowId String @unique
  nextStableIdN     Int    @default(1)
  viewX             Float  @default(0)
  viewY             Float  @default(0)
  zoom              Float  @default(1)

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)
}

// ============================================================
// Admin Notes — unchanged from pre-Phase M.
// Note: `system` values expand in Phase M to include
// "dashboard" and "plos" (in addition to "pms" and
// "think-tank"). The schema needs no change — enforcement
// of valid values happens in application code.
// ============================================================
model AdminNote {
  id          String   @id @default(uuid())
  userId      String
  system      String
  title       String   @default("Untitled Note")
  description String   @default("") @db.Text
  content     String   @default("") @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attachments NoteAttachment[]

  @@index([userId, system])
}

model NoteAttachment {
  id          String   @id @default(uuid())
  noteId      String
  fileName    String
  fileType    String
  fileSize    Int
  storagePath String
  publicUrl   String
  createdAt   DateTime @default(now())

  note AdminNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

// ============================================================
// W#2 Competition Scraping & Deep Analysis tables.
// Added 2026-05-06 in W#2 PLOS-side build first session.
// Spec: docs/COMPETITION_SCRAPING_STACK_DECISIONS.md §9.1.
// ============================================================

// CompetitorUrl — one row per (Project's W#2 workflow, platform, URL).
model CompetitorUrl {
  id                  String   @id @default(uuid())
  projectWorkflowId   String // FK to ProjectWorkflow where workflow="competition-scraping"
  platform            String // "amazon" | "ebay" | "etsy" | "walmart" | "google-shopping" | "google-ads" | "independent-website"
  url                 String   @db.Text
  competitionCategory String? // value from VocabularyEntry; null until user fills
  productName         String? // value from VocabularyEntry; null until user fills
  brandName           String? // value from VocabularyEntry; null until user fills
  resultsPageRank     Int?
  productStarRating   Float? // 0.0–5.0
  sellerStarRating    Float? // 0.0–5.0 (Etsy primarily)
  numProductReviews   Int?
  numSellerReviews    Int?
  isSponsoredAd       Boolean  @default(false) // P-6 — manual checkbox in URL-add form; auto-pre-checks for Amazon SSPA-detected URLs (P-4 synergy)
  customFields        Json     @default("{}") // { fieldName: value } user-defined product-scoped fields
  addedBy             String // userId
  addedAt             DateTime @default(now())
  updatedAt           DateTime @updatedAt

  projectWorkflow ProjectWorkflow  @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)
  sizes           CompetitorSize[]
  capturedTexts   CapturedText[]
  capturedImages  CapturedImage[]

  @@unique([projectWorkflowId, platform, url])
  @@index([projectWorkflowId, platform])
}

// CompetitorSize — one row per Size/Option under a CompetitorUrl.
model CompetitorSize {
  id              String   @id @default(uuid())
  competitorUrlId String
  sizeOption      String // free-text per §A.7
  price           Decimal? @db.Decimal(10, 2)
  shippingCost    Decimal? @db.Decimal(10, 2)
  customFields    Json     @default("{}") // size-scoped user-defined fields
  sortOrder       Int      @default(0)
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
}

// CapturedText — one row per highlighted-and-saved text snippet.
model CapturedText {
  id              String   @id @default(uuid())
  clientId        String   @unique // UUIDv4 from extension; idempotency key
  competitorUrlId String
  contentCategory String? // value from VocabularyEntry
  text            String   @db.Text
  tags            Json     @default("[]") // string[]
  sortOrder       Int      @default(0)
  addedBy         String // userId
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
  @@index([competitorUrlId, contentCategory])
}

// CapturedImage — one row per saved image (regular product shot OR region-screenshot).
model CapturedImage {
  id              String   @id @default(uuid())
  clientId        String   @unique
  competitorUrlId String
  imageCategory   String? // value from VocabularyEntry
  storagePath     String // e.g., "{projectId}/{competitorUrlId}/{capturedImageId}.png"
  storageBucket   String   @default("competition-scraping")
  composition     String?  @db.Text // describes what's IN the image
  embeddedText    String?  @db.Text // text that appears INSIDE the image
  tags            Json     @default("[]")
  sourceType      String // "regular" | "region-screenshot"
  fileSize        Int? // bytes
  mimeType        String?
  width           Int? // pixels
  height          Int?
  sortOrder       Int      @default(0)
  addedBy         String
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
  @@index([competitorUrlId, imageCategory])
}

// VocabularyEntry — platform-shared vocabularies per PLATFORM_REQUIREMENTS.md §8.4.
// Project-scoped, NOT workflow-scoped. Any workflow on the same Project can READ + ADD.
model VocabularyEntry {
  id              String   @id @default(uuid())
  projectId       String
  vocabularyType  String // "competition-category" | "product-name" | "brand-name" | "content-category" | "image-category" | "custom-field-name-product" | "custom-field-name-size"
  value           String
  addedByWorkflow String // which workflow originated this entry
  addedBy         String // userId
  addedAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, vocabularyType, value])
  @@index([projectId, vocabularyType])
}

// ============================================================
// Cross-workflow tables (designed now, used by Phase 2 / Phase 3
// platform-wide work; W#2 is the first declarer per §9.1).
// ============================================================

// WorkerAssignment — Phase 2; per PLATFORM_REQUIREMENTS.md §2.2.1.
// Hard rule per W#2 §A.2: exactly one assignment per (project, workflow, subScope).
model WorkerAssignment {
  id          String    @id @default(uuid())
  userId      String
  projectId   String
  workflow    String // "competition-scraping" | "keyword-clustering" | etc.
  subScope    String? // for W#2: platform name; null for workflows without sub-scope
  status      String    @default("active") // "active" | "completed" | "revoked"
  assignedAt  DateTime  @default(now())
  assignedBy  String // admin userId
  completedAt DateTime?

  @@unique([projectId, workflow, subScope])
  @@index([userId, status])
  @@index([projectId, workflow])
}

// AuditEvent — Phase 3; per PLATFORM_REQUIREMENTS.md §5.5.
model AuditEvent {
  id           String   @id @default(uuid())
  workflowType String // "competition-scraping" | "keyword-clustering" | etc.
  projectId    String
  userId       String
  eventType    String // "capture" | "edit" | "delete" | "vocabulary-add" | etc.
  payload      Json // event-specific structured data
  timestamp    DateTime @default(now())

  @@index([projectId, workflowType])
  @@index([userId, timestamp])
}

// UserProjectHighlightTerm — W#2 P-3 (narrowed), 2026-05-10.
// Per-user-per-project Highlight Terms list, stored server-side so signing
// in from any device / any Chrome profile preserves the configured terms.
// Replaces the prior chrome.storage.local-only storage that was lost on
// every extension reinstall. One row per (user, project, term).
model UserProjectHighlightTerm {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  term      String
  color     String // 7-char hex from §6 20-color palette
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId, term])
  @@index([userId, projectId])
}

// UserExtensionState — W#2 P-3 (broader scope), 2026-05-10-e.
// Per-user W#2 Chrome extension state — last-picked Project + last-picked
// Platform — stored server-side so signing in from any device / Chrome
// profile preserves the user's setup picks. Closes the broader-P-3 scope
// left open after the Highlight Terms portion shipped 2026-05-10.
// Schema-shape decision (Rule 18 mid-build Read-It-Back): single record
// per user with two scalar columns, preserving today's chrome.storage.local
// behavior 1:1 (switching project clears platform — server enforces this
// invariant on PUT). One row per user; userId is the natural one-row key.
model UserExtensionState {
  id                String   @id @default(uuid())
  userId            String   @unique
  selectedProjectId String?
  selectedPlatform  String?
  updatedAt         DateTime @updatedAt

  @@index([userId])
}
