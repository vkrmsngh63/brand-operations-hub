// ============================================================
// PLOS database schema — Phase M
// User-facing concept: "Project" (one product launch effort)
// Internal structure: Project + ProjectWorkflow (user never sees
// the name "ProjectWorkflow" — it's pure DB implementation)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Project — user-facing record.
// One Project = one product launch effort.
// Flows through all 14 PLOS workflows via ProjectWorkflow rows.
// ============================================================
model Project {
  id          String   @id @default(uuid())
  userId      String
  name        String   @default("Untitled Project")
  description String   @default("") @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflows             ProjectWorkflow[]
  vocabularyEntries     VocabularyEntry[]
  comprehensiveAnalysis ComprehensiveCompetitorAnalysis?

  @@index([userId])
}

// ============================================================
// ProjectWorkflow — internal per-workflow state + data bucket.
// User never sees this name in the UI.
// Auto-created on first workflow entry; auto-transitions
// "inactive" -> "active" on first real action; "completed"
// is user-marked.
// ============================================================
model ProjectWorkflow {
  id              String    @id @default(uuid())
  projectId       String
  workflow        String // "keyword-clustering", etc.
  status          String    @default("inactive") // "inactive" | "active" | "completed"
  firstActivityAt DateTime?
  lastActivityAt  DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keywords        Keyword[]
  removedKeywords RemovedKeyword[]
  canvasNodes     CanvasNode[]
  pathways        Pathway[]
  sisterLinks     SisterLink[]
  canvasState     CanvasState?
  competitorUrls  CompetitorUrl[]

  @@unique([projectId, workflow])
  @@index([projectId])
}

// ============================================================
// Keyword — attached to a workflow instance (was: Project).
// All fields unchanged; only the foreign key target changed.
// ============================================================
model Keyword {
  id                String   @id @default(uuid())
  projectWorkflowId String
  keyword           String
  volume            Int      @default(0)
  sortingStatus     String   @default("Unsorted")
  tags              String   @default("")
  topic             String   @default("")
  canvasLoc         Json     @default("{}")
  topicApproved     Json     @default("{}")
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

// ============================================================
// CanvasNode — attached to a workflow instance (was: Project).
// All fields unchanged; only the foreign key target changed.
// ============================================================
model CanvasNode {
  id                String   @id @default(uuid())
  projectWorkflowId String
  title             String   @default("")
  description       String   @default("")
  x                 Float    @default(0)
  y                 Float    @default(0)
  w                 Float    @default(220)
  h                 Float    @default(120)
  baseY             Float    @default(0)
  pathwayId         String?
  parentId          String?
  relationshipType  String   @default("")
  linkedKwIds       Json     @default("[]")
  kwPlacements      Json     @default("{}")
  collapsedLinear   Boolean  @default(false)
  collapsedNested   Boolean  @default(false)
  narrativeBridge   String   @default("")
  altTitles         Json     @default("[]")
  userMinH          Float?
  connCP            Json?
  connOutOff        Json?
  connInOff         Json?
  sortOrder         Int      @default(0)
  stableId          String
  stabilityScore    Float    @default(0.0)
  // Intent fingerprint — short canonical phrase (5–15 words, searcher-centric)
  // capturing a topic's compound intent. Load-bearing for Tiered Canvas
  // Serialization (Scale Sessions B–E in INPUT_CONTEXT_SCALING_DESIGN.md).
  // Scale Session B Step 1: nullable. Step 2: AI backfill. Step 3: NOT NULL.
  intentFingerprint String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@unique([projectWorkflowId, stableId])
  @@index([projectWorkflowId])
}

// ============================================================
// RemovedKeyword — soft-archive of keywords removed from an
// AST table. Preserves the keyword's prior state so admin can
// review or restore. Two removal sources today:
//   "manual" — admin clicked Remove in the AST table
//   "auto-ai-detected-irrelevant" — Auto-Analyze salvage
//   mechanism flagged as irrelevant (Session 3b)
// `aiReasoning` is the model's text rationale for auto removals.
// ============================================================
model RemovedKeyword {
  id                String   @id @default(uuid())
  projectWorkflowId String
  originalKeywordId String?
  keyword           String
  volume            Int      @default(0)
  sortingStatus     String   @default("Unsorted")
  tags              String   @default("")
  topic             String   @default("")
  canvasLoc         Json     @default("{}")
  removedAt         DateTime @default(now())
  removedBy         String
  removedSource     String   @default("manual")
  aiReasoning       String?  @db.Text

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

model Pathway {
  id                String   @id @default(uuid())
  projectWorkflowId String
  createdAt         DateTime @default(now())

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

model SisterLink {
  id                String   @id @default(uuid())
  projectWorkflowId String
  nodeA             String
  nodeB             String
  createdAt         DateTime @default(now())

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)

  @@index([projectWorkflowId])
}

model CanvasState {
  id                String @id @default(uuid())
  projectWorkflowId String @unique
  nextStableIdN     Int    @default(1)
  viewX             Float  @default(0)
  viewY             Float  @default(0)
  zoom              Float  @default(1)

  projectWorkflow ProjectWorkflow @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)
}

// ============================================================
// Admin Notes — unchanged from pre-Phase M.
// Note: `system` values expand in Phase M to include
// "dashboard" and "plos" (in addition to "pms" and
// "think-tank"). The schema needs no change — enforcement
// of valid values happens in application code.
// ============================================================
model AdminNote {
  id          String   @id @default(uuid())
  userId      String
  system      String
  title       String   @default("Untitled Note")
  description String   @default("") @db.Text
  content     String   @default("") @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attachments NoteAttachment[]

  @@index([userId, system])
}

model NoteAttachment {
  id          String   @id @default(uuid())
  noteId      String
  fileName    String
  fileType    String
  fileSize    Int
  storagePath String
  publicUrl   String
  createdAt   DateTime @default(now())

  note AdminNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

// ============================================================
// W#2 Competition Scraping & Deep Analysis tables.
// Added 2026-05-06 in W#2 PLOS-side build first session.
// Spec: docs/COMPETITION_SCRAPING_STACK_DECISIONS.md §9.1.
// ============================================================

// CompetitorUrl — one row per (Project's W#2 workflow, platform, URL).
model CompetitorUrl {
  id                  String  @id @default(uuid())
  projectWorkflowId   String // FK to ProjectWorkflow where workflow="competition-scraping"
  platform            String // "amazon" | "ebay" | "etsy" | "walmart" | "google-shopping" | "google-ads" | "independent-website"
  url                 String  @db.Text
  competitionCategory String? // value from VocabularyEntry; null until user fills
  productName         String? // value from VocabularyEntry; null until user fills
  brandName           String? // value from VocabularyEntry; null until user fills
  resultsPageRank     Int?
  productStarRating   Float? // 0.0–5.0
  sellerStarRating    Float? // 0.0–5.0 (Etsy primarily)
  numProductReviews   Int?
  numSellerReviews    Int?
  isSponsoredAd       Boolean @default(false) // P-6 — manual checkbox in URL-add form; auto-pre-checks for Amazon SSPA-detected URLs (P-4 synergy)
  customFields        Json    @default("{}") // { fieldName: value } user-defined product-scoped fields
  source              String  @default("extension") // P-29 Slice #1 — "extension" | "manual"; audit-trail of which client created the row.

  // P-46 Workstream 1 (2026-05-24) — Phase 2 Competition Data redesign per docs/COMPETITION_DATA_V2_DESIGN.md §A.11.
  // Additive columns; all nullable or defaulted so existing rows render unchanged.
  type                      String?
  description1              String?        @db.Text
  description2              String?        @db.Text
  price                     String? // free-text per §A.11 — accommodates "$24.99" / "From $24" / "Free w/ Prime"
  competitionScore          Int? // 1-100; range validated at application layer per §A.7
  scrapingStatus            ScrapingStatus @default(INCOMPLETE) // bidirectional mirror with table Status column per §A.8
  overallCompetitorAnalysis Json           @default("{}") // TipTap document JSON per §A.5
  overallAnalyses           Json           @default("{}") // bag: { "text": <TipTap>, "image": <TipTap>, "video": <TipTap>, "reviews": <TipTap> } per §A.11

  // P-49 Workstream 2 (2026-05-26) — Reviews Phase 2 per docs/REVIEWS_PHASE_2_DESIGN.md §A.4 + §A.16.
  // Per-URL review scrape cap; editable via click-to-edit cell from P-46 W3 Session 2; per-trigger override
  // available in trigger popup. Default 200 reviews per star (or per filter, depending on platform).
  reviewScrapeCap Int? @default(200)

  addedBy   String // userId
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectWorkflow ProjectWorkflow    @relation(fields: [projectWorkflowId], references: [id], onDelete: Cascade)
  sizes           CompetitorSize[]
  capturedTexts   CapturedText[]
  capturedImages  CapturedImage[]
  capturedVideos  CapturedVideo[]
  capturedReviews CapturedReview[]
  reviewAnalyses  ReviewAnalysis[]

  @@unique([projectWorkflowId, platform, url])
  @@index([projectWorkflowId, platform])
}

// CompetitorSize — one row per Size/Option under a CompetitorUrl.
model CompetitorSize {
  id              String   @id @default(uuid())
  competitorUrlId String
  sizeOption      String // free-text per §A.7
  price           Decimal? @db.Decimal(10, 2)
  shippingCost    Decimal? @db.Decimal(10, 2)
  customFields    Json     @default("{}") // size-scoped user-defined fields
  sortOrder       Int      @default(0)
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
}

// CapturedText — one row per highlighted-and-saved text snippet.
model CapturedText {
  id              String   @id @default(uuid())
  clientId        String   @unique // UUIDv4 from extension; idempotency key
  competitorUrlId String
  contentCategory String? // value from VocabularyEntry
  text            String   @db.Text
  // P-25 (2026-05-19-f): serialized selector describing where the captured
  // text lived in the source page's DOM, so the content-script can re-locate
  // the Range on later page loads and render a light-yellow haze over it.
  // Shape: JSON-encoded {xpath: string, startOffset: number, endOffset: number}
  // resolved against document.body. Nullable for rows captured before P-25
  // (no recoverable selector); set for new captures via the right-click
  // text-capture flow. See extensions/competition-scraping/src/lib/
  // captured-text-selector.ts for the encode/decode contract.
  selector        String?  @db.Text
  tags            Json     @default("[]") // string[]
  sortOrder       Int      @default(0)
  source          String   @default("extension") // P-29 Slice #1 — "extension" | "manual"; audit-trail of which client created the row.
  analysis        Json     @default("{}") // P-46 (2026-05-24) — TipTap document JSON for the per-item Analysis text box per §A.11
  addedBy         String // userId
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
  @@index([competitorUrlId, contentCategory])
}

// CapturedImage — one row per saved image (regular product shot OR region-screenshot).
model CapturedImage {
  id              String   @id @default(uuid())
  clientId        String   @unique
  competitorUrlId String
  imageCategory   String? // value from VocabularyEntry
  storagePath     String // e.g., "{projectId}/{competitorUrlId}/{capturedImageId}.png"
  storageBucket   String   @default("competition-scraping")
  // Host-page <img>.src this row was captured from. Nullable because
  // pre-existing rows have no recoverable source; new rows persist the src
  // so the content-script can render a "saved" indicator on matching <img>
  // elements on the live page.
  originalSrcUrl  String?
  composition     String?  @db.Text // describes what's IN the image
  embeddedText    String?  @db.Text // text that appears INSIDE the image
  tags            Json     @default("[]")
  sourceType      String // "regular" | "region-screenshot"
  fileSize        Int? // bytes
  mimeType        String?
  width           Int? // pixels
  height          Int?
  sortOrder       Int      @default(0)
  source          String   @default("extension") // P-29 Slice #1 — "extension" | "manual"; audit-trail of which client created the row (distinct from sourceType which describes the image's content shape).
  analysis        Json     @default("{}") // P-46 (2026-05-24) — TipTap document JSON for the per-item Analysis text box per §A.11
  addedBy         String
  addedAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
  @@index([competitorUrlId, imageCategory])
}

// CapturedVideo — one row per saved video (direct-bytes upload OR embed reference).
// Added 2026-05-21 in W#2 polish P-27 Build #1. Spec: docs/CAPTURED_VIDEOS_DESIGN.md §A.7.
// Mirrors CapturedImage with 3 video-specific additions (sourceType discriminator,
// durationSeconds, thumbnailStoragePath) + nullable storage fields for embed rows.
model CapturedVideo {
  id              String @id @default(uuid())
  clientId        String @unique // UUIDv4 from extension; idempotency key
  competitorUrlId String
  projectId       String // denormalized for fast Project-scope queries + cascade-on-Project-reset

  // Source discrimination — EMBED rows reference a YouTube/Vimeo URL only (no bytes);
  // DIRECT_BYTES rows have uploaded video bytes in Supabase Storage.
  sourceType     VideoSourceType
  originalSrcUrl String          @db.Text // ALWAYS present — embed URL OR page-host URL for direct-bytes

  // Bytes-stored fields (NULL when sourceType=EMBED)
  storagePath     String?
  storageBucket   String? // "competition-scraping-videos" when set
  fileSize        Int? // bytes
  mimeType        String? // "video/mp4" | "video/webm" | "video/quicktime" when set
  durationSeconds Float? // nullable since embed paths can't read this without download
  width           Int? // intrinsic videoWidth
  height          Int? // intrinsic videoHeight

  // Thumbnail (nullable per §A.12 fallback — save never blocked on thumbnail failure)
  thumbnailStoragePath String? // direct-bytes: canvas frame-grab uploaded as JPEG; embed: NULL (computed at render time)

  // Categorization
  videoCategory String? // value from VocabularyEntry (vocabularyType="video-category")
  composition   String? @db.Text
  embeddedText  String? @db.Text
  tags          Json    @default("[]")

  sortOrder Int @default(0)

  source    String   @default("extension") // "extension" | "manual"
  analysis  Json     @default("{}") // P-46 (2026-05-24) — TipTap document JSON for the per-item Analysis text box per §A.11
  addedBy   String // userId
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([competitorUrlId])
  @@index([competitorUrlId, videoCategory])
}

// VideoSourceType — Prisma enum discriminator for CapturedVideo rows per §A.7 + §C.1 #12.
// EMBED = YouTube/Vimeo/etc. reference (URL only, no bytes).
// DIRECT_BYTES = uploaded video file (bytes in competition-scraping-videos bucket).
// SCREEN_RECORDING = recorded webm clip via getDisplayMedia + MediaRecorder (P-45 2026-05-22).
//   Bytes stored in the same bucket as DIRECT_BYTES; originalSrcUrl stores the page URL.
enum VideoSourceType {
  EMBED
  DIRECT_BYTES
  SCREEN_RECORDING
}

// ScrapingStatus — P-46 Workstream 1 (2026-05-24) per docs/COMPETITION_DATA_V2_DESIGN.md §A.8.
// Bidirectional mirror between the URL detail page's Scraping Status toggle and the
// Competition Data table's Status column. Both reads + writes go through CompetitorUrl.scrapingStatus.
enum ScrapingStatus {
  INCOMPLETE
  COMPLETE
}

// CapturedReview — one row per captured product review against a CompetitorUrl.
// P-46 Workstream 1 (2026-05-24) per §A.1b. v1: source="manual" (vklf.com-side manual entry form).
// P-49 Workstream 2 (2026-05-26) — Reviews Phase 2 per docs/REVIEWS_PHASE_2_DESIGN.md §A.16.
// Extension-extracted reviews use source="extension-scrape". New additive columns: sortRank for
// drag-to-reorder (§A.5), helpfulCount for Amazon "X people found this helpful" (§A.16; null on
// platforms without helpful-count signal), platform denormalized for cross-product queries.
model CapturedReview {
  id              String    @id @default(uuid())
  clientId        String    @unique // UUIDv4 from client; idempotency key
  competitorUrlId String
  starRating      Int // 1-5; range validated at application layer per §A.1b
  title           String?   @db.Text // P-49 W5 Reviews Phase 2 Fix Session B (2026-05-30) — review headline; extractors capture it, orchestrator now passes it through. Nullable: pre-2026-05-30 rows + body-only reviews (eBay/Etsy + ~60% of Walmart) carry null. Table renders 'title. body' merge at display time.
  body            String    @db.Text
  reviewerName    String?
  reviewDate      DateTime?
  tags            Json      @default("[]") // string[]
  analysis        Json      @default("{}") // TipTap document JSON for per-item Analysis box per §A.11
  source          String    @default("manual") // "manual" in v1; "extension-scrape" added P-49 W2; future per-platform values
  sortRank        Int? // P-49 W4 — server-side drag-to-reorder per §A.5; null = insertion order
  sortRankInReviewsTable Int? // P-49 W5 Reviews Phase 2 Fix Session C (2026-05-29) — per-page drag-to-reorder of review rows WITHIN a URL on the Competitor Reviews Analysis Table page (Q5 → A; page-specific, NOT propagated to the URL detail page). null = insertion order.
  helpfulCount    Int? // P-49 W2 — Amazon-supplied "X people found this helpful"; null for eBay/Etsy/Walmart
  platform        String? // P-49 W2 — denormalized from parent CompetitorUrl for cross-product queries
  addedBy         String // userId
  addedAt         DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  competitorUrl CompetitorUrl @relation(fields: [competitorUrlId], references: [id], onDelete: Cascade)

  @@index([competitorUrlId])
}

// ComprehensiveCompetitorAnalysis — one row per Project per §A.4. Single rich-text doc
// (TipTap JSON) synthesizing across ALL competitors + platforms in this Project. Hyperlinks
// can point back to per-URL detail pages.
// P-46 Workstream 1 (2026-05-24).
model ComprehensiveCompetitorAnalysis {
  id           String   @id @default(uuid())
  projectId    String   @unique // exactly one per Project
  contentJson  Json     @default("{}") // TipTap document JSON per §A.5
  lastEditedBy String
  lastEditedAt DateTime @updatedAt
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ReviewAnalysis — one row per AI-generated review summary at one of three aggregation
// levels per docs/REVIEWS_PHASE_2_DESIGN.md §A.10 + §A.16. Cached + re-runnable per §A.12.
// Discriminated by level; scope fields populated based on level:
//   PER_PRODUCT — urlId set, projectId/typeFilter null
//   PER_TYPE    — projectId + typeFilter set, urlId null
//   PER_PROJECT — projectId set, urlId/typeFilter null
// P-49 Workstream 5 ships read+write code consuming this model; schema lands here in
// W2 Amazon Session 1 (2026-05-26) as the foundation step per §A.13.
model ReviewAnalysis {
  id            String              @id @default(uuid())
  level         ReviewAnalysisLevel
  // Scope fields — exactly one combination set per level (validated at application layer):
  urlId         String?
  projectId     String?
  typeFilter    String?
  // Analysis payload + cache key per §A.9 + §A.12:
  analysisJson  Json                @default("{}") // TipTap document JSON per §A.9
  reviewsHash   String // SHA-256(sorted review IDs + modelVersion) per §A.12 fingerprint cache
  modelVersion  String // "claude-opus-4-7" | "claude-opus-4-6" | future per §A.7
  // Audit:
  runAt         DateTime            @default(now())
  runByUserId   String? // null if run by automation (not used in v1 per §A.11 manual-trigger lock)
  costUsdMicros Int? // total cost in millionths of a dollar; nullable since some API responses omit cost

  competitorUrl CompetitorUrl? @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@index([urlId])
  @@index([projectId, level])
  @@index([projectId, typeFilter])
  @@index([reviewsHash])
}

// ReviewAnalysisLevel — discriminator for ReviewAnalysis rows.
// Initial spec: docs/REVIEWS_PHASE_2_DESIGN.md §A.10 (PER_PRODUCT/PER_TYPE/PER_PROJECT).
// Extended 2026-06-XX by the Reviews Phase 3 expansion §B entry — PER_REVIEW + PER_CATEGORY
// added to cover the 7-flow per-review + per-competitor + per-category + per-type analysis
// surfaces described in the new 3-table top-toggle design.
//   PER_REVIEW  — one analysis per CapturedReview (uses urlId + reviewId scope via a JSON ref);
//                 cache key for Flow 1 "Auto-Summarize Reviews" per-review bullet summaries.
//   PER_PRODUCT — one analysis per CompetitorUrl (uses urlId scope); covers Flows 2 + 3
//                 (per-competitor comprehensive bulleted + non-bulleted).
//   PER_CATEGORY — one analysis per (projectId, category) pair pooling all products in that
//                  category; covers Flows 4 + 5 (per-category comprehensive bulleted + non-bulleted).
//                  Stores category name in typeFilter column (reused; rename deferred to future).
//   PER_TYPE    — one analysis per (projectId, typeFilter) pair pooling all products of that Type;
//                 covers Flows 6 + 7 (per-type comprehensive bulleted + non-bulleted).
//   PER_PROJECT — reserved for future cross-Project competitive landscape analysis (no flow ships
//                 in the current 7-flow expansion).
enum ReviewAnalysisLevel {
  PER_REVIEW
  PER_PRODUCT
  PER_CATEGORY
  PER_TYPE
  PER_PROJECT
}

// UserTablePreferences — per-user-per-project UI preferences for the Competition Data table
// per §A.3. Server-side storage enables cross-device sync (column widths / visibility / font
// size / row order survive login on a different device). Joins UserExtensionState +
// UserProjectHighlightTerm as the third per-user-per-project preference table per §A.12.
// P-46 Workstream 1 (2026-05-24).
model UserTablePreferences {
  id                    String   @id @default(uuid())
  userId                String
  projectId             String
  columnVisibility      Json     @default("{}") // { columnId: boolean }
  columnWidths          Json     @default("{}") // { columnId: pixels }
  fontSize              Int      @default(14) // 10-24 range; validated at application layer
  rowOrder              Json     @default("[]") // [competitorUrlId] in user's preferred order
  lastUsedSortColumn    String?
  lastUsedSortDirection String? // "asc" | "desc" — validated at application layer
  // W#2 P-49 W5 Category page "interactive batch" (2026-05-30). Per-user,
  // per-Project "memory" for the Reviews Analysis By Competitor Category
  // page ONLY — scoped to that page, never shared with the Content Table or
  // Reviews Analysis Table (which use rowOrder). Additive + nullable:
  // { categoryOrder: string[], rowOrderByUrlId: string[],
  //   hiddenUrlIds: string[], hiddenCategoryKeys: string[] }. The sibling
  // Reviews Analysis By Competitor Type page gets its own typeTableLayout
  // column when it's built (Sessions 4-5).
  categoryTableLayout   Json?
  // W#2 P-49 W5 Type page Sessions 4-5 (2026-05-31). The parallel per-user,
  // per-Project "memory" for the Reviews Analysis By Competitor Type page
  // ONLY — same shape as categoryTableLayout with the grouping key swapped:
  // { typeOrder: string[], rowOrderByUrlId: string[],
  //   hiddenUrlIds: string[], hiddenTypeKeys: string[] }. Additive + nullable.
  typeTableLayout       Json?
  updatedAt             DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
}

// W#2 P-54 Phase 3 (2026-06-01) — SHARED, per-Project layout for the main
// /competition-scraping Competitor URLs table. Director directive: column
// order, show/hide, widths, competitor row order, and font size are all
// SHARED across everyone on the Project (one coherent layout), not per-user.
// Keyed by projectId @unique (no userId). The per-user UserTablePreferences
// above is left intact and still backs the per-user Reviews Analysis
// By-Category / By-Type page layouts (categoryTableLayout / typeTableLayout);
// this model takes over ONLY the main table's layout fields. On first read the
// project row is seeded from the requesting user's existing UserTablePreferences
// so a pre-existing layout is preserved (handler seed-on-read). Additive new
// table → zero data loss to existing tables.
model ProjectTablePreferences {
  id                    String   @id @default(uuid())
  projectId             String   @unique
  columnOrder           Json     @default("[]") // [columnId] left-to-right arranged order
  columnVisibility      Json     @default("{}") // { columnId: boolean }
  columnWidths          Json     @default("{}") // { columnId: pixels }
  fontSize              Int      @default(14) // 10-24 range; validated at application layer
  rowOrder              Json     @default("[]") // [competitorUrlId] in arranged order
  // P-54 Phase 4 (2026-06-01) — "Sort By" row grouping, shared per-Project.
  groupBy               String   @default("none") // "none" | "platform" | "category" | "type" — validated at application layer
  groupOrder            Json     @default("{}") // { platform?: [key], category?: [key], type?: [key] } — saved banner order per mode
  lastUsedSortColumn    String?
  lastUsedSortDirection String? // "asc" | "desc" — validated at application layer
  updatedAt             DateTime @updatedAt
}

// VocabularyEntry — platform-shared vocabularies per PLATFORM_REQUIREMENTS.md §8.4.
// Project-scoped, NOT workflow-scoped. Any workflow on the same Project can READ + ADD.
model VocabularyEntry {
  id              String   @id @default(uuid())
  projectId       String
  vocabularyType  String // "competition-category" | "product-name" | "brand-name" | "content-category" | "image-category" | "video-category" | "custom-field-name-product" | "custom-field-name-size"
  value           String
  addedByWorkflow String // which workflow originated this entry
  addedBy         String // userId
  addedAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, vocabularyType, value])
  @@index([projectId, vocabularyType])
}

// ============================================================
// Cross-workflow tables (designed now, used by Phase 2 / Phase 3
// platform-wide work; W#2 is the first declarer per §9.1).
// ============================================================

// WorkerAssignment — Phase 2; per PLATFORM_REQUIREMENTS.md §2.2.1.
// Hard rule per W#2 §A.2: exactly one assignment per (project, workflow, subScope).
model WorkerAssignment {
  id          String    @id @default(uuid())
  userId      String
  projectId   String
  workflow    String // "competition-scraping" | "keyword-clustering" | etc.
  subScope    String? // for W#2: platform name; null for workflows without sub-scope
  status      String    @default("active") // "active" | "completed" | "revoked"
  assignedAt  DateTime  @default(now())
  assignedBy  String // admin userId
  completedAt DateTime?

  @@unique([projectId, workflow, subScope])
  @@index([userId, status])
  @@index([projectId, workflow])
}

// AuditEvent — Phase 3; per PLATFORM_REQUIREMENTS.md §5.5.
model AuditEvent {
  id           String   @id @default(uuid())
  workflowType String // "competition-scraping" | "keyword-clustering" | etc.
  projectId    String
  userId       String
  eventType    String // "capture" | "edit" | "delete" | "vocabulary-add" | etc.
  payload      Json // event-specific structured data
  timestamp    DateTime @default(now())

  @@index([projectId, workflowType])
  @@index([userId, timestamp])
}

// UserProjectHighlightTerm — W#2 P-3 (narrowed), 2026-05-10.
// Per-user-per-project Highlight Terms list, stored server-side so signing
// in from any device / any Chrome profile preserves the configured terms.
// Replaces the prior chrome.storage.local-only storage that was lost on
// every extension reinstall. One row per (user, project, term).
model UserProjectHighlightTerm {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  term      String
  color     String // 7-char hex from §6 20-color palette
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId, term])
  @@index([userId, projectId])
}

// UserExtensionState — W#2 P-3 (broader scope), 2026-05-10-e.
// Per-user W#2 Chrome extension state — last-picked Project + last-picked
// Platform — stored server-side so signing in from any device / Chrome
// profile preserves the user's setup picks. Closes the broader-P-3 scope
// left open after the Highlight Terms portion shipped 2026-05-10.
// Schema-shape decision (Rule 18 mid-build Read-It-Back): single record
// per user with two scalar columns, preserving today's chrome.storage.local
// behavior 1:1 (switching project clears platform — server enforces this
// invariant on PUT). One row per user; userId is the natural one-row key.
model UserExtensionState {
  id                String   @id @default(uuid())
  userId            String   @unique
  selectedProjectId String?
  selectedPlatform  String?
  updatedAt         DateTime @updatedAt

  @@index([userId])
}
