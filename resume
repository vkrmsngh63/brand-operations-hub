#!/usr/bin/env bash
# resume — one-command session-start for PLOS Claude Code sessions.
#
# Reads docs/NEXT_SESSION.md (written by the previous session's end-of-session
# checklist per HANDOFF_PROTOCOL.md §4 Step 1 row 12), switches to the branch
# the pointer names, pulls the latest, prints the pointer's contents so the
# director sees what's about to happen, then launches `claude`.
#
# A `SessionStart` hook (`.claude/hooks/inject-next-session-pointer.sh`,
# wired in `.claude/settings.json`) fires when claude launches; it reads
# the SAME `docs/NEXT_SESSION.md` file and injects its contents as a system
# reminder BEFORE the user's first prompt. Claude then has the pointer-file
# content as context — no manual paste needed. The director still types ONE
# thing (e.g., "go" + Enter) to wake Claude up; this is a hard constraint
# of Claude Code's interactive-mode CLI (positional `[prompt]` does NOT
# auto-submit in interactive mode — only with `-p` print mode).
#
# Multi-layered defense per HANDOFF_PROTOCOL Rule 28:
#   Layer 1 (primary, mechanical): SessionStart hook injects pointer as system reminder
#   Layer 2 (procedural fallback): CLAUDE_CODE_STARTER.md sentinel-handling rule — if user pastes the sentinel string manually OR types "resume per docs/NEXT_SESSION.md", Claude follows the pointer
#   Layer 3 (manual escape hatch): 3-step path documented in every handoff — cd + checkout + paste full launch prompt
#   Layer 4 (procedural enforcement): NEXT_SESSION.md guard hook (.claude/hooks/check-next-session-doc.sh) blocks End-of-session commits without an updated pointer file
#
# Cross-references:
#   docs/CLAUDE_CODE_STARTER.md — sentinel-handling section (Layer 1 + Layer 2)
#   docs/HANDOFF_PROTOCOL.md Rule 28 — Resume-flow multi-layered defense
#   .claude/hooks/inject-next-session-pointer.sh — the SessionStart hook this script depends on
#   .claude/settings.json — hook wiring

set -euo pipefail

POINTER="docs/NEXT_SESSION.md"

abort() {
  echo ""
  echo "❌ resume aborted: $1"
  echo ""
  echo "Fall back to the 3-step escape hatch documented in"
  echo "docs/CLAUDE_CODE_STARTER.md → \"HOW TO START A NEW CLAUDE CODE SESSION\":"
  echo ""
  echo "  1. Switch branch + pull the latest. For W#1 / platform-wide work that's:"
  echo "       cd /workspaces/brand-operations-hub && git fetch origin && git checkout main && git pull --rebase origin main"
  echo "     For W#k feature branches replace 'main' with the workflow branch name."
  echo "  2. Launch Claude Code:"
  echo "       claude"
  echo "  3. Paste the launch prompt verbatim from your most recent end-of-session"
  echo "     handoff message (or from docs/NEXT_SESSION.md if it exists)."
  exit 1
}

if [ ! -f "$POINTER" ]; then
  abort "$POINTER not found. The previous session was supposed to write this file at end-of-session (per HANDOFF_PROTOCOL.md §4 Step 1 row 12). The next session should also log this as a CORRECTIONS_LOG.md entry."
fi

BRANCH=$(awk '/^## Branch[[:space:]]*$/{getline; while ($0 ~ /^[[:space:]]*$/) getline; print; exit}' "$POINTER" | tr -d '[:space:]')

if [ -z "$BRANCH" ]; then
  abort "Could not read the 'Branch' field from $POINTER. The file may be malformed."
fi

echo "── resume — session pointer ──"
echo "Branch: $BRANCH"
echo ""

git fetch origin || abort "git fetch origin failed."
git checkout "$BRANCH" || abort "git checkout $BRANCH failed. If you have uncommitted changes, stash or commit them before re-running ./resume."
git pull --rebase origin "$BRANCH" || abort "git pull --rebase origin $BRANCH failed. Resolve any conflicts before re-running ./resume."

echo ""
echo "── docs/NEXT_SESSION.md (the pointer the previous session left for this one) ──"
echo ""
cat "$POINTER"
echo ""
echo "════════════════════════════════════════════════════════════════════"
echo "  Launching Claude Code now."
echo ""
echo "  📌 IMPORTANT: when Claude finishes loading, type any single word"
echo "     (e.g., 'go' or 'proceed') and press Enter."
echo ""
echo "     The SessionStart hook will have already injected the pointer"
echo "     content above into the session as context, so Claude will"
echo "     immediately follow the pointer's '## Launch prompt' section"
echo "     once you send your first message. NO COPY-PASTE NEEDED."
echo ""
echo "     If for any reason Claude doesn't act on the pointer after your"
echo "     first message, fall back to pasting the launch prompt manually"
echo "     from the pointer contents printed above (the 3-step escape hatch)."
echo "════════════════════════════════════════════════════════════════════"
echo ""

# NOTE: We do NOT pass a positional [prompt] argument to claude here.
# Claude Code's positional [prompt] only auto-submits in non-interactive
# mode (`-p`). In interactive mode it pre-fills the input box silently or
# is ignored — director would still have to manually press Enter or paste.
# The SessionStart hook handles context injection; the director's single
# wake-up keystroke is the minimum interaction Claude Code's CLI requires.
exec claude
